# Live mode launcher switch
TRADING_MODE=live

# Live Polymarket auth
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
POLYMARKET_FUNDER=0xYOUR_FUNDER_WALLET_ADDRESS
POLYMARKET_PUBLIC_ADDRESS=0xYOUR_PUBLIC_WALLET_ADDRESS

# L2 API credentials
POLYMARKET_API_KEY=YOUR_API_KEY
POLYMARKET_API_SECRET=YOUR_API_SECRET
POLYMARKET_API_PASSPHRASE=YOUR_API_PASSPHRASE

# Optional / advanced
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137

# FIX: Changed from 0 to 1.
# Signature type tells the CLOB which wallet setup you use:
#   0 = EOA (direct wallet, no Polymarket proxy)
#   1 = Email / Magic / Google login on Polymarket.com (proxy wallet)
#   2 = MetaMask / Rabby browser wallet on Polymarket.com (proxy wallet)
# If you log into Polymarket with email, use 1.
POLYMARKET_SIGNATURE_TYPE=1

# Keep or remove paper-only values; they are not used by strict live launcher
# PAPER_TRADE_MODE=True
# SIMULATED_STARTING_BALANCE=1000
# MAX_RISK_PER_TRADE=50
